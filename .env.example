# ===== LLM API 配置（支持 OpenAI SDK 格式的任意 LLM API）=====
# 推荐方案1：阿里百炼平台 qwen-plus
# 说明：https://bailian.console.aliyun.com/
# 注意：消耗较大，可先进行小于40轮的模拟尝试
# LLM_API_KEY=your_dashscope_api_key_here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-plus

# 推荐方案2：OpenRouter (使用 Nvidia Nemotron-3-Super 免费模型)
# 说明：https://openrouter.ai/
# 获取API Key：https://openrouter.ai/keys
# 模型资源：https://openrouter.ai/models
LLM_API_KEY=sk-or-v1-your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.io/api/v1
LLM_MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free

# ===== ZEP 记忆图谱配置 =====
# 说明：https://app.getzep.com/
# 每月免费额度即可支撑简单使用
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 如果需要使用并行加速模式，可配置以下选项
# 注意：如果不使用加速配置，请注释掉以下配置项
# LLM_BOOST_API_KEY=sk-or-v1-your_boost_api_key_here
# LLM_BOOST_BASE_URL=https://openrouter.io/api/v1
# LLM_BOOST_MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free